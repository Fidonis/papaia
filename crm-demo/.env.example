# ═══════════════════════════════════════════════════════════════════════════
# crm-demo — environment variables
# by Fidonis GmbH · https://fidonis.de
# ═══════════════════════════════════════════════════════════════════════════
# Copy to .env and fill in real values. Never commit .env.
# ═══════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────
ESPOCRM_DB_NAME=espocrm
ESPOCRM_DB_USER=espocrm
ESPOCRM_DB_PASSWORD=GENERATE_NEW_PASSWORD
ESPOCRM_DB_ROOT_PASSWORD=GENERATE_NEW_ROOT_PASSWORD

# ── EspoCRM bootstrap admin ───────────────────────────────────────────────
# Created on first container start during the unattended install.
ESPOCRM_ADMIN_USERNAME=admin
ESPOCRM_ADMIN_PASSWORD=GENERATE_NEW_ADMIN_PASSWORD

# Public URL used by EspoCRM to build links / cookies. Change to your real
# host when exposing beyond localhost.
ESPOCRM_SITE_URL=http://localhost:8080

# ── Host ports ────────────────────────────────────────────────────────────
ESPOCRM_EXT_PORT=9000
ESPOCRM_WS_EXT_PORT=9001
MCP_EXT_PORT=9010

# ── MCP server (zaphod-black/EspoMCP) ─────────────────────────────────────
# Create an API user inside EspoCRM (Administration → API Users), copy its
# API key here, then start the espocrm-mcp service.
ESPOCRM_API_KEY=
# 'apikey' or 'hmac'. For 'hmac', also set ESPOCRM_SECRET_KEY below.
ESPOCRM_AUTH_METHOD=apikey
ESPOCRM_SECRET_KEY=

MCP_RATE_LIMIT=100
MCP_REQUEST_TIMEOUT=30000
MCP_LOG_LEVEL=info
