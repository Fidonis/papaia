# ----------------------------------------------------------------------
# Configuration
# ----------------------------------------------------------------------
TECHNITIUM_IMAGE=technitium/dns-server:14.3.0
TECHNITIUM_HEALTHCHECK_INTERVAL=30s
TECHNITIUM_HEALTHCHECK_TIMEOUT=10s
TECHNITIUM_HEALTHCHECK_RETRIES=5
TECHNITIUM_HEALTHCHECK_START_PERIOD=40s

# ----------------------------------------------------------------------
# Basic server identity
# ----------------------------------------------------------------------
DNS_SERVER_HOSTNAME=dns-serversrc/infra/technitium/.env.example           # Hostname that the DNS server identifies itself with
DNS_SERVER_DOMAIN=papaia.local           #  Domain name that the DNS server uses to identify itself

# ----------------------------------------------------------------------
# Admin access (password options)
# ----------------------------------------------------------------------
# You can either provide a clear‑text password or the path to a file that
# contains the password.  Use *only one* of the two variables – leave the
# other empty.
DNS_SERVER_ADMIN_PASSWORD=papAIa2026     # Clear‑text admin password (for demo/testing only)
# DNS_SERVER_ADMIN_PASSWORD_FILE=/run/secrets/dns-admin-pwd.txt # Path to a file with the admin password

# ----------------------------------------------------------------------
# Network and protocol options
# ----------------------------------------------------------------------
DNS_SERVER_PREFER_IPV6=false                  # Prefer IPv6 for queries whenever possible
#  Comma‑separated list of interface IPs the web service should listen on.
#  “172.17.0.1” is Docker’s default bridge address.  “[::]” is the default
#  value when nothing is specified.  Note: only use this together with
#  “host” network mode.
DNS_SERVER_WEB_SERVICE_LOCAL_ADDRESSES=172.17.0.1,127.0.0.1
DNS_SERVER_WEB_SERVICE_HTTP_PORT=5380
DNS_SERVER_WEB_SERVICE_HTTPS_PORT=53443
DNS_SERVER_WEB_SERVICE_ENABLE_HTTPS=false
#  Use a self‑signed TLS certificate for the DNS web console
DNS_SERVER_WEB_SERVICE_USE_SELF_SIGNED_CERT=false
#  File path to the TLS certificate (PFX/PKCS#12 format)
DNS_SERVER_WEB_SERVICE_TLS_CERTIFICATE_PATH=/etc/dns/tls/cert.pfx
DNS_SERVER_WEB_SERVICE_TLS_CERTIFICATE_PASSWORD=certPassword
DNS_SERVER_WEB_SERVICE_HTTP_TO_TLS_REDIRECT=false

# ----------------------------------------------------------------------
# Protocol extensions
# ----------------------------------------------------------------------
DNS_SERVER_OPTIONAL_PROTOCOL_DNS_OVER_HTTP=false   # DNS‑over‑HTTP (Port 8053) aktivieren

# ----------------------------------------------------------------------
# Recursion / ACL rules
# ----------------------------------------------------------------------
DNS_SERVER_RECURSION=AllowOnlyForPrivateNetworks
DNS_SERVER_RECURSION_NETWORK_ACL=192.168.10.0/24,!192.168.10.2
# # (obsolete – use the ACL above)
# DNS_SERVER_RECURSION_DENIED_NETWORKS=     #Comma separated list of IP addresses or network addresses to deny recursion.
# DNS_SERVER_RECURSION_ALLOWED_NETWORKS=    #Comma separated list of IP addresses or network addresses to allow recursion.

# ----------------------------------------------------------------------
# Blocking / filtering
# ----------------------------------------------------------------------
DNS_SERVER_ENABLE_BLOCKING=false
DNS_SERVER_ALLOW_TXT_BLOCKING_REPORT=false
DNS_SERVER_BLOCK_LIST_URLS=               # z. B. https://example.com/blocklist.txt,https://another.org/list.txt

# ----------------------------------------------------------------------
# Forwarders
# ----------------------------------------------------------------------
DNS_SERVER_FORWARDERS=1.1.1.1,8.8.8.8   # Comma‑separated list of upstream DNS forwarder IPs
DNS_SERVER_FORWARDER_PROTOCOL=Tcp       # Forwarder protocol: Udp, Tcp, Tls, Https, HttpsJson
DNS_SERVER_LOG_USING_LOCAL_TIME=true    # Use local time (instead of UTC) for log timestamps