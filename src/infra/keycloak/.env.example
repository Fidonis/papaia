# ═══════════════════════════════════════════════════════════════════════════
# papAIa — Keycloak · environment variables
# by Fidonis GmbH · https://fidonis.de
# ═══════════════════════════════════════════════════════════════════════════

# --- Database ---
KC_DB_USER=papaia_keycloak
KC_DB_PASSWORD=keycloak

# --- Admin Bootstrap ---
KC_ADMIN_PASSWORD=password   # Change this! Used only on first start.

# --- Client Secrets ---
# Injected into realm-import/papaia-realm.json at import time via
# ${env.KC_*} substitution — replace each placeholder with a secure
# random value, e.g.: openssl rand -hex 24
KC_LIBRECHAT_CLIENT_SECRET=GENERATE_KC_LIBRECHAT_CLIENT_SECRET
KC_PAPERLESS_CLIENT_SECRET=GENERATE_KC_PAPERLESS_CLIENT_SECRET
KC_LITELLM_CLIENT_SECRET=GENERATE_KC_LITELLM_CLIENT_SECRET
KC_OAUTH2_PROXY_CLIENT_SECRET=GENERATE_KC_OAUTH2_PROXY_CLIENT_SECRET
KC_QDRANT_RAG_CLIENT_SECRET=GENERATE_KC_QDRANT_RAG_CLIENT_SECRET

# --- Hostname ---
# Public URL of Keycloak written into token "iss" claims and OIDC discovery docs.
# Must be reachable from BOTH the browser AND other Docker containers.
#
# Default uses host.docker.internal:
#   - macOS / Windows Docker Desktop: works out-of-the-box
#   - Linux: add "127.0.0.1 host.docker.internal" to /etc/hosts
#
# For production replace with your real domain:
#   KC_HOSTNAME=https://auth.yourdomain.com
KC_HOSTNAME=http://host.docker.internal:8110

# --- Reverse-proxy mode ---
# Required when an edge proxy (Caddy / Traefik / nginx) terminates TLS in
# front of Keycloak and forwards plain HTTP. Without this, Keycloak logs
#   WARN  Likely misconfiguration detected. When using an edge proxy, you
#         must use `proxy-headers`.
#   WARN  Non-secure context detected; cookies are not secured […]
# and emits non-Secure session cookies, which the browser then drops on
# the cross-origin OIDC POST → "Unknown OAuth error" at login.
#
# Set to empty when running Keycloak directly exposed without a proxy.
KC_PROXY_HEADERS=xforwarded
