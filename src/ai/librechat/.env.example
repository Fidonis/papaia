# ═══════════════════════════════════════════════════════════════════════════
# papAIa — LibreChat · environment variables
# by Fidonis GmbH · https://fidonis.de
# ═══════════════════════════════════════════════════════════════════════════

# --- Core secrets (replace each GENERATE_… placeholder) ---
CREDS_KEY=GENERATE_CREDS_KEY
CREDS_IV=GENERATE_CREDS_IV
JWT_SECRET=GENERATE_JWT_SECRET
JWT_REFRESH_SECRET=GENERATE_JWT_REFRESH_SECRET

# --- Server ---
PORT=3080
HOST=0.0.0.0
TRUST_PROXY=1
NODE_MAX_OLD_SPACE_SIZE=6144
NO_INDEX=true
ENDPOINTS=custom,agents

# --- MeiliSearch ---
MEILI_MASTER_KEY=GENERATE_MEILI_MASTER_KEY

# --- Vector DB (RAG) ---
VECTORDB_NAME=librechat
VECTORDB_USER=lcvdbuser
VECTORDB_PASSWORD=GENERATE_VECTORDB_PASSWORD
RAG_PORT=8020

# --- LiteLLM integration ---
# Must match LITELLM_MASTER_KEY in ai/litellm/.env
LITELLM_API_KEY=GENERATE_LITELLM_API_KEY

# --- Keycloak SSO ---
# Client secret must match KC_LIBRECHAT_CLIENT_SECRET in src/infra/keycloak/.env
# Generate one secret and paste the same value into both files
OPENID_CLIENT_ID=librechat
OPENID_CLIENT_SECRET=GENERATE_LIBRECHAT_CLIENT_SECRET
# Must match the iss claim in Keycloak tokens (= KC_HOSTNAME/realms/papaia)
# Derived from PAPAIA_HOST
OPENID_ISSUER=http://host.docker.internal:8110/realms/papaia
OPENID_SCOPE=openid profile email
OPENID_CALLBACK_URL=/oauth/openid/callback
OPENID_SESSION_SECRET=GENERATE_OPENID_SESSION_SECRET
OPENID_BUTTON_LABEL=Sign in with Keycloak
OPENID_USE_END_SESSION_ENDPOINT=true
OPENID_REUSE_TOKENS=true
# Must match the Keycloak client setting (pkce.code.challenge.method=S256 in realm config)
OPENID_USE_PKCE=true
OPENID_USERNAME_CLAIM=preferred_username
OPENID_EMAIL_CLAIM=email
# Restrict login to users with this role (empty = allow all authenticated users)
OPENID_REQUIRED_ROLE=
OPENID_REQUIRED_ROLE_PARAMETER_PATH=roles
OPENID_REQUIRED_ROLE_TOKEN_KIND=userinfo

# Public URL of LibreChat — must be reachable by the user's browser
# Derived from PAPAIA_HOST
DOMAIN_SERVER=http://host.docker.internal:8000
DOMAIN_CLIENT=http://host.docker.internal:8000

# --- Auth: SSO only (no local email/password login) ---
ALLOW_EMAIL_LOGIN=true
ALLOW_REGISTRATION=true
ALLOW_SOCIAL_LOGIN=true
ALLOW_SOCIAL_REGISTRATION=true
ALLOW_PASSWORD_RESET=false
ALLOW_UNVERIFIED_EMAIL_LOGIN=true

# --- UI ---
APP_TITLE=papAIa Chat by Fidonis
HELP_AND_FAQ_URL=https://librechat.ai

# --- Web Search (optional — requires SearXNG and FireCrawl services) ---
SEARXNG_INSTANCE_URL=http://searxng:8080
SEARXNG_API_KEY=sk-not-used
FIRECRAWL_API_KEY=sk-not-used
FIRECRAWL_API_URL=http://firecrawl:3002
FIRECRAWL_VERSION=v1
JINA_API_KEY=sk-not-used
JINA_API_URL=http://notused:8000/rerank

# --- Image Generation (optional — requires compatible endpoint) ---
# IMAGE_GEN_OAI_API_KEY=sk-your-key
# IMAGE_GEN_OAI_BASEURL=http://litellm:4000/
# IMAGE_GEN_OAI_MODEL=gpt-image-1.5

# MS Office Document Creator
MCP_OFFICE_DOCS_API_KEY=GENERATE_MCP_OFFICE_DOCS_API_KEY
