# ═══════════════════════════════════════════════════════════════════════════
# papAIa — LiteLLM · environment variables
# by Fidonis GmbH · https://fidonis.de
# ═══════════════════════════════════════════════════════════════════════════

# --- Core secrets (generated by setup-papaia.sh) ---
LITELLM_MASTER_KEY=GENERATE_LITELLM_MASTER_KEY
LITELLM_SALT_KEY=GENERATE_LITELLM_SALT_KEY
LITELLM_PG_PASSWORD=GENERATE_LITELLM_PG_PASSWORD

# --- Optional: Mammouth.ai ---
# API key from https://mammouth.ai — leave empty to disable
MAMMOUTH_API_KEY=
MAMMOUTH_API_BASE=https://api.mammouth.ai/v1

# --- Optional: OpenRouter ---
# API key from https://openrouter.ai — leave empty to disable
OPENROUTER_API_KEY=

# --- SSO behaviour ---
AUTO_REDIRECT_UI_LOGIN_TO_SSO=true

# --- Keycloak SSO ---
# Client secret must match KC_LITELLM_CLIENT_SECRET in src/infra/keycloak/.env
GENERIC_CLIENT_ID=litellm
GENERIC_CLIENT_SECRET=GENERATE_LITELLM_CLIENT_SECRET
# Browser-facing auth URL — must be reachable by the user's browser
GENERIC_AUTHORIZATION_ENDPOINT=http://host.docker.internal:8110/realms/papaia/protocol/openid-connect/auth
# Server-side endpoints — use internal Docker DNS
GENERIC_TOKEN_ENDPOINT=http://keycloak:8080/realms/papaia/protocol/openid-connect/token
GENERIC_USERINFO_ENDPOINT=http://keycloak:8080/realms/papaia/protocol/openid-connect/userinfo
# Redirect URI — must be reachable by the browser after login
GENERIC_REDIRECT_URI=http://host.docker.internal:8200/sso/callback
GENERIC_SCOPE=openid profile email
GENERIC_USER_ID_ATTRIBUTE=sub
GENERIC_USER_EMAIL_ATTRIBUTE=email
GENERIC_USER_DISPLAY_NAME_ATTRIBUTE=preferred_username
GENERIC_USER_ROLE_ATTRIBUTE=roles
GENERIC_ROLE_MAPPINGS_GROUP_CLAIM=roles
GENERIC_ROLE_MAPPINGS_ROLES={"proxy_admin": ["admin"], "internal_user": ["user"]}
GENERIC_ROLE_MAPPINGS_DEFAULT_ROLE=internal_user
PROXY_LOGOUT_URL=http://host.docker.internal:8110/realms/papaia/protocol/openid-connect/logout?client_id=litellm&post_logout_redirect_uri=http://host.docker.internal:8200/sso/key/generate
