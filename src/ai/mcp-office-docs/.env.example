# ═══════════════════════════════════════════════════════════════════════════
# papAIa — mcp-office-docs · environment variables
# by Fidonis GmbH · https://fidonis.de
#
# Image and external port live in the root .env (MCP_OFFICE_DOCS_IMAGE,
# MCP_OFFICE_DOCS_EXT_PORT).
# ═══════════════════════════════════════════════════════════════════════════

# --- Storage ---
UPLOAD_STRATEGY=MINIO
# Internal Docker DNS hostname of the MinIO service.
MINIO_ENDPOINT=minio:9000
# Must match MINIO_ROOT_USER / MINIO_ROOT_PASSWORD in services/minio/.env.
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=GENERATE_MINIO_ROOT_PASSWORD
MINIO_BUCKET=librechat-office-documents
# Set to "true" when MinIO is served behind HTTPS.
MINIO_SECURE=false
# Lifetime of pre-signed download URLs in seconds (default: 1 hour).
SIGNED_URL_EXPIRES_IN=3600

# --- Optional API key ---
# When set, LibreChat must pass this key via the Authorization header.
# Leave empty to rely on Docker network isolation alone.
# API_KEY=
