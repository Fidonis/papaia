# papAIa — mcp-paperless · environment variables
# by Fidonis GmbH · https://fidonis.de
#
# These variables live in the ROOT .env (src/.env), not here.
# This file exists for documentation purposes only.
# ═══════════════════════════════════════════════════════════════════════════

# OIDC audience — must match the Audience mapper on the LibreChat Keycloak client
MCP_PAPERLESS_OIDC_AUDIENCE=mcp-paperless

# OIDC issuer is inherited from OIDC_ISSUER in root .env (no duplicate needed)

# Internal Paperless URL — never changes in Docker Compose
# PAPERLESS_URL=http://paperless:8000 (hardcoded in docker-compose.yml)
