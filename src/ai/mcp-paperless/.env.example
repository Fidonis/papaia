# ═══════════════════════════════════════════════════════════════════════════
# papAIa — mcp-paperless · environment variables
# by Fidonis GmbH · https://fidonis.de
#
# OIDC_ISSUER is reused from the global OIDC block — no duplicate needed.
# Image and external port live in the root .env (MCP_PAPERLESS_IMAGE,
# MCP_PAPERLESS_EXT_PORT).
# ═══════════════════════════════════════════════════════════════════════════

# --- OIDC / Keycloak ---
# Audience must match the Audience mapper on the LibreChat Keycloak client.
MCP_PAPERLESS_OIDC_AUDIENCE=mcp-paperless
MCP_PAPERLESS_OIDC_JWKS_CACHE_TTL=3600

# --- Paperless-ngx ---
# Internal URL reachable on papaia-net.
MCP_PAPERLESS_PAPERLESS_URL=http://paperless:8000
# Wire header the MCP server sends to Paperless as the remote-user identifier.
# Must match PAPERLESS_HTTP_REMOTE_USER_HEADER_NAME in services/paperless, whose
# WSGI form is the uppercased, underscored value prefixed with HTTP_:
#   X-Papaia-Remote-User  <->  HTTP_X_PAPAIA_REMOTE_USER
MCP_PAPERLESS_REMOTE_USER_HEADER=X-Papaia-Remote-User
MCP_PAPERLESS_USERNAME_CLAIM=preferred_username
MCP_PAPERLESS_HTTP_TIMEOUT=30
MCP_PAPERLESS_MAX_DOWNLOAD_BYTES=10485760

# --- MCP server ---
MCP_PAPERLESS_MCP_HOST=0.0.0.0
MCP_PAPERLESS_MCP_PORT=8000
MCP_PAPERLESS_MCP_PATH=/mcp

# --- Logging ---
MCP_PAPERLESS_LOG_LEVEL=INFO
