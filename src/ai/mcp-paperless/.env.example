# ═══════════════════════════════════════════════════════════════════════════
# papAIa — mcp-paperless · environment variables
# by Fidonis GmbH · https://fidonis.de
#
# These variables live in the ROOT .env (src/.env), not here.
# They must match the values in services/paperless/.env.
# This file exists for documentation purposes only.
# ═══════════════════════════════════════════════════════════════════════════

# Internal URL of the Paperless-ngx container (never changes in Docker Compose)
# PAPERLESS_URL=http://paperless:8000

# Browser-facing public URL — set in the root .env (src/.env)
# PAPERLESS_PUBLIC_URL=http://host.docker.internal:8010

# Admin credentials — must match services/paperless/.env
# PAPERLESS_ADMIN_USER=paperless-admin
# PAPERLESS_ADMIN_PASSWORD=<generated>
