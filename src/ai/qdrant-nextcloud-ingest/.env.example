# ═══════════════════════════════════════════════════════════════════════════
# papAIa — qdrant-nextcloud-ingest · environment variables
# by Fidonis GmbH · https://fidonis.de
#
# These variables live in the ROOT .env (src/.env). This file documents
# the qdrant-nextcloud-ingest block; it is not loaded directly.
# ═══════════════════════════════════════════════════════════════════════════

# ── Images ───────────────────────────────────────────────────────────────────
QNC_SYNC_IMAGE=rclone/rclone:latest
QNC_INGEST_IMAGE=papaia-qdrant-nextcloud-ingest:latest

# ── Qdrant (target — usually the qdrant-rag Qdrant on papaia-net) ────────────
QNC_QDRANT_URL=http://qdrant:6333
# Same value as QDRANT_RAG_QDRANT_JWT_SECRET so authenticated writes succeed.
QNC_QDRANT_API_KEY=change-me-to-a-strong-secret

# ── Embeddings via LiteLLM (papaia-net service) ──────────────────────────────
LITELLM_URL=http://litellm:4000/v1
LITELLM_API_KEY=sk-papaia-default-key
QNC_EMBED_MODEL=nomic-embed-text
# The Qdrant collection that qdrant-rbac reads for per-collection embedding
# model metadata. Keep identical to QDRANT_RAG_EMBEDDING_META_COLLECTION.
QNC_EMBED_META_COLLECTION=_collection_meta

# ── WebDAV sources (N = 1, 2, ...) — values are read by sync.sh + ingester ──
# Comma-separated list of source names that the ingester exposes via the
# list_sources MCP tool. Each name MUST correspond to a WEBDAV_<N>_NAME below.
QNC_WEBDAV_SOURCES=nextcloud

WEBDAV_1_NAME=nextcloud
WEBDAV_1_URL=https://nextcloud.example.com/remote.php/dav/files/USERNAME/
WEBDAV_1_USER=username
WEBDAV_1_PASS=app-password
WEBDAV_1_VENDOR=nextcloud
# WEBDAV_2_NAME=...

# ── Sync & scan intervals (seconds) ──────────────────────────────────────────
QNC_SYNC_INTERVAL=60
QNC_SCAN_INTERVAL=60

# ── Chunking & embedding ─────────────────────────────────────────────────────
QNC_CHUNK_WORDS=400
QNC_CHUNK_OVERLAP=50
QNC_EMBED_BATCH_SIZE=32

# ── Ingest MCP server (internal on papaia-net unless explicitly published) ──
QNC_INGEST_MCP_HOST=0.0.0.0
QNC_INGEST_MCP_PORT=8100
QNC_INGEST_MCP_PATH=/mcp

# ── Logging ──────────────────────────────────────────────────────────────────
QNC_LOG_LEVEL=INFO
