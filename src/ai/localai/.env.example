# Logging
LOCALAI_LOG_LEVEL=info
LOCALAI_DEBUG=false

# Healthcheck — increase start_period when downloading large GPU models on first start
LOCALAI_HEALTHCHECK_INTERVAL=30s
LOCALAI_HEALTHCHECK_TIMEOUT=10s
LOCALAI_HEALTHCHECK_RETRIES=5
LOCALAI_HEALTHCHECK_START_PERIOD=40s

