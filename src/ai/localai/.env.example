######################################
#  Contains variables for LocalAI  #
######################################

# LocalAI Image Selection
# Exactly ONE of the following should be active

# CPU (stable, recommended default — includes llama-cpp and all standard backends)
LOCALAI_IMAGE=localai/localai:v4.1.0

# NVIDIA GPU (requires NVIDIA Container Toolkit + compatible drivers)
# LOCALAI_IMAGE=localai/localai:v4.1.0-gpu-nvidia-cuda-12

# NVIDIA GPU (requires NVIDIA Container Toolkit + compatible drivers)
# LOCALAI_IMAGE=localai:sha-6c635e8-gpu-nvidia-cuda-13

# Port mapping (host port -> container port 8080)
LOCALAI_EXT_PORT=8080

# Logging
LOCALAI_LOG_LEVEL=info
LOCALAI_DEBUG=false

# Healthcheck
LOCALAI_HEALTHCHECK_INTERVAL=30s
LOCALAI_HEALTHCHECK_TIMEOUT=10s
LOCALAI_HEALTHCHECK_RETRIES=5

LOCALAI_HEALTHCHECK_START_PERIOD=300s

# Docker network (must exist externally)
DOCKER_NETWORK=hs-net