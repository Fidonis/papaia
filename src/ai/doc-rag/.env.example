# papAIa — doc-rag · environment variables
# by Fidonis GmbH · https://fidonis.de
# ═══════════════════════════════════════════════════════════════════════════

# ── WebDAV sources ────────────────────────────────────────────────────────────
# Add as many sources as needed (increment N: 1, 2, 3, ...).
# Each source gets its own sync loop and its own Qdrant collection.
# NAME becomes both /data/docs/{NAME}/ and the collection name.
# Directory names are automatically sanitized (lowercase, hyphens only).
# VENDOR: use "nextcloud" for Nextcloud, "webdav" for generic WebDAV (default).

WEBDAV_1_NAME=nextcloud
WEBDAV_1_URL=https://nextcloud.example.com/remote.php/dav/files/USERNAME/
WEBDAV_1_USER=username
WEBDAV_1_PASS=app-password            # Nextcloud: Settings → Security → App passwords
WEBDAV_1_VENDOR=nextcloud

# WEBDAV_2_NAME=sharepoint
# WEBDAV_2_URL=https://company.sharepoint.com/documents/
# WEBDAV_2_USER=user@company.com
# WEBDAV_2_PASS=password
# WEBDAV_2_VENDOR=sharepoint

# ── Intervals (seconds) ───────────────────────────────────────────────────────
SYNC_INTERVAL=60    # how often rclone pulls from remote sources
SCAN_INTERVAL=60    # how often the ingester scans /data/docs for changes

# ── LiteLLM ───────────────────────────────────────────────────────────────────
LITELLM_URL=http://litellm:4000/v1
# Copy LITELLM_MASTER_KEY from src/ai/litellm/.env
LITELLM_API_KEY=sk-papaia-default-key

# ── Embedding model ───────────────────────────────────────────────────────────
# mammouth-embed  → cloud embedding via Mammouth (requires MAMMOUTH_API_KEY in litellm/.env)
# nomic-embed-text → local embedding via LocalAI (requires LocalAI + model download)
EMBED_MODEL=mammouth-embed

# ── Ingester tuning ───────────────────────────────────────────────────────────
CHUNK_WORDS=400       # words per chunk
CHUNK_OVERLAP=50      # words of overlap between consecutive chunks

# ── Docling PDF parsing ────────────────────────────────────────────────────────
# Disabled by default for speed — digital PDFs (born-digital, not scanned) need neither.
# Enable DOCLING_OCR=true only for scanned/image-only PDFs.
DOCLING_OCR=false
DOCLING_TABLES=false

# ── API tuning ────────────────────────────────────────────────────────────────
DEFAULT_TOP_K=5       # default number of results returned
DEFAULT_MIN_SCORE=0.5 # minimum cosine similarity score (0.0–1.0)
