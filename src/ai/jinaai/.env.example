# papAIa — JinaAI · environment variables
# by Fidonis GmbH · https://fidonis.de
# ═══════════════════════════════════════════════════════════════════════════

# Inbound API key — LibreChat sends this as JINA_API_KEY (must match ai/librechat/.env)
JINAAI_RERANKER_API_KEY=GENERATE_JINAAI_RERANKER_API_KEY

# LiteLLM backend (outbound — must match ai/litellm/.env)
LITELLM_API_KEY=sk-Your_LiteLLM_API_Key
LITELLM_BASE_URL=http://litellm:4000

# Reranker model served by LiteLLM
RERANKER_MODEL=YOUR_RERANKER_MODEL_NAME

# Hard cap on the number of documents forwarded to the rerank backend.
# LiteLLM enforces a maximum of 1024; set lower to reduce backend load.
MAX_RERANK_DOCS=1024
# Timeout in seconds for outgoing requests to the rerank backend.
# Increase for slow or large models (default: 60).
BACKEND_TIMEOUT=60