# ═══════════════════════════════════════════════════════════════════════════
# papAIa — qdrant-rag · environment variables
# by Fidonis GmbH · https://fidonis.de
#
# These variables live in the ROOT .env (src/.env), not here.
# OIDC_ISSUER is reused from the global OIDC block — no duplicate needed.
# This file exists for documentation purposes only.
# ═══════════════════════════════════════════════════════════════════════════

# --- OIDC / Keycloak ---
QDRANT_RAG_OIDC_AUDIENCE=qdrant-rag
QDRANT_RAG_OIDC_JWKS_CACHE_TTL=3600

# --- Qdrant ---
QDRANT_RAG_QDRANT_URL=http://qdrant:6333
QDRANT_RAG_QDRANT_JWT_SECRET=GENERATE_A_STRONG_SECRET_AND_SET_HERE
QDRANT_RAG_QDRANT_JWT_TTL=3600

# --- MCP server ---
QDRANT_RAG_MCP_HOST=0.0.0.0
QDRANT_RAG_MCP_PORT=8000
QDRANT_RAG_MCP_PATH=/mcp

# --- Logging ---
QDRANT_RAG_LOG_LEVEL=INFO            # DEBUG / INFO / WARNING / ERROR (default: INFO)

# --- Embeddings ---
QDRANT_RAG_EMBEDDING_API_URL=http://host.docker.internal:11434/v1
QDRANT_RAG_EMBEDDING_API_KEY=sk-YOURKEYHERE
QDRANT_RAG_EMBEDDING_META_COLLECTION=_collection_meta

# --- RBAC ---
QDRANT_RAG_RBAC_ADMIN_ROLE=qdrant-admin
QDRANT_RAG_RBAC_ACL_COLLECTION=_rbac_acl
QDRANT_RAG_RBAC_ACL_CACHE_TTL=60
QDRANT_RAG_RBAC_SERVICE_TOKEN_TTL=300
