# ═══════════════════════════════════════════════════════════════════════════
# papAIa — Global Stack Configuration · environment variables
# by Fidonis GmbH · https://fidonis.de
# ═══════════════════════════════════════════════════════════════════════════

# papAIa stack version — do not edit
PAPAIA_VERSION=

COMPOSE_PROJECT_NAME=papaia
# Only the default modules are listed here. Add the modules you enable
# to this comma-separated list (e.g. n8n / homepage / paperless /
# searxng / localai / doc-rag). Listing a
# profile whose .env file has not been generated breaks `docker compose
# config` with "env file not found".
COMPOSE_PROFILES=keycloak,nginx,oauth2-proxy,librechat,litellm
DOCKER_NETWORK="papaia-net"
TIMEZONE="Europe/Berlin"

# =============================================================================
# Externalised service configuration directory
# =============================================================================
# Path on the host where customer-specific service configuration lives. The
# directory layout inside it MIRRORS the layout under src/ (e.g.
# ai/librechat/librechat.yaml, infra/keycloak/keycloak.conf,
# services/homepage/config/services.yaml, ...).
#
# All bind-mounted configuration files that used to be sourced from inside
# the cloned repo (`./<file>` in src/**/docker-compose.yml) are now sourced
# from ${PAPAIA_CONFIG_DIR}/<mirrored-path>. The repo ships canonical
# defaults under src/; the running stack only ever reads from this directory.
# Customer edits therefore never produce a git diff in the checkout.
#
# IMPORTANT — set this to an ABSOLUTE PATH. Docker Compose `include:`d files
# resolve relative paths against their OWN directory, so a relative value
# like "./config" would resolve differently per service and not work.
#
# Populate the directory once with the shipped defaults via:
#     src/sync-config.sh                    # uses $PAPAIA_CONFIG_DIR from .env
#     src/sync-config.sh /custom/path       # or pass an explicit target
# The script is non-destructive: existing files in the target are kept.
#
# Examples:
#   Linux:   PAPAIA_CONFIG_DIR=/srv/papaia/config
#   macOS:   PAPAIA_CONFIG_DIR=/Users/<you>/papaia-config
#   Windows: PAPAIA_CONFIG_DIR=C:/papaia-config   (forward slashes)
PAPAIA_CONFIG_DIR=/srv/papaia/config

# Host user IDs — set these so bind-mounted files are owned by the
# correct user on Linux. On macOS/Windows Docker Desktop these are ignored.
UID=1000
GID=1000

# =============================================================================
# Multi-env stack bindings (network layer)
# =============================================================================
#
# HOST_IP — which host IP the container ports will be bound to.
# This is the NETWORK layer: where the Docker host listens externally.
#
#   - Default 0.0.0.0 = all interfaces (single-stack setup, behaves as before)
#   - Multi-env setup: each stack uses its own IP so two stacks with
#     identical compose files and identical ports can run in parallel on the
#     same host (e.g. via IP aliases on the host's network interface).
#
#
# Do NOT confuse with PAPAIA_HOST (see "Server base URL" block below):
#   - PAPAIA_HOST = public URL (application layer) — browser redirects,
#     OIDC issuer, OIDC callback URLs, etc. Tells the apps how they present
#     themselves to the outside world.
#   - HOST_IP    = bind address (network layer) — tells Docker which host IP
#     should expose each container port.
#
HOST_IP=0.0.0.0

# =============================================================================
# Server base URL
# =============================================================================
# Public base URL of this server — no trailing slash.
# Used to build LibreChat / LiteLLM / Paperless / n8n / Homepage public URLs.
# Must be reachable from BOTH the browser AND Docker containers.
#
# macOS / Windows Docker Desktop:  http://host.docker.internal  (default)
# Linux server with a fixed IP:    http://192.168.1.100
# Production with a domain:        https://papaia.example.com
PAPAIA_HOST=http://host.docker.internal

# =============================================================================
# Auth host (Keycloak public URL)
# =============================================================================
# Public URL of the Keycloak admin console / OIDC issuer — no trailing slash.
# This is what ends up in token "iss" claims, OIDC discovery documents and
# every browser-facing login redirect, so it MUST be the URL the user types
# into the browser, not the internal IP+port the container listens on.
#
# Direct LAN setup (no reverse proxy): same host as PAPAIA_HOST plus the
#   Keycloak port, e.g.  http://192.168.1.100:8110
# Behind a reverse proxy (Caddy / Traefik / NPM) that terminates TLS for
#   Keycloak under its own FQDN:  https://auth.papaia.example.com
#   (any FQDN works — there is no enforced "auth." subdomain convention.)
#
# Set this to the public Keycloak URL (scheme, host and port included).
AUTH_HOST=http://host.docker.internal:8110

# =============================================================================
# Authentication Provider
# =============================================================================
# internal_keycloak  - Use the bundled Keycloak (default, zero config needed)
# external_oidc      - Use an existing external OIDC/IdP (Keycloak, Entra,
#                      Authentik, Okta, ...) configured via OIDC_* vars below
AUTH_PROVIDER=internal_keycloak

# =============================================================================
# OIDC / Identity Provider Configuration
# =============================================================================
# Pre-filled for the internal Keycloak default. Override for external providers.
OIDC_ISSUER=http://host.docker.internal:8110/realms/papaia
OIDC_CLIENT_ID=librechat
OIDC_SCOPES=openid profile email
OIDC_ROLE_CLAIM=roles
OIDC_USERNAME_CLAIM=preferred_username
OIDC_EMAIL_CLAIM=email

# Split OIDC endpoint URLs for oauth2-proxy (--skip-oidc-discovery mode):
#   KC_AUTH  — browser-facing login redirect (must be reachable by the user's browser)
#   KC_TOKEN — server-side token exchange (uses internal Docker DNS, never hit by browser)
#   KC_CERTS — server-side JWKS fetch (uses internal Docker DNS)
# For internal Keycloak: browser URLs use host.docker.internal, server URLs use keycloak:8080.
# For external OIDC: set all three to your provider's real endpoints.
OIDC_ISSUER_KC_AUTH=http://host.docker.internal:8110/realms/papaia/protocol/openid-connect/auth
# Token + JWKS endpoints stay on internal Docker DNS — never hit by the browser:
OIDC_ISSUER_KC_TOKEN=http://keycloak:8080/realms/papaia/protocol/openid-connect/token
OIDC_ISSUER_KC_CERTS=http://keycloak:8080/realms/papaia/protocol/openid-connect/certs

OAUTH2_PROXY_IMAGE=quay.io/oauth2-proxy/oauth2-proxy:v7.9.0
OAUTH2_PROXY_EXT_PORT=4180
OAUTH2_PROXY_CLIENT_ID=oauth2-proxy
OAUTH2_PROXY_CLIENT_SECRET=GENERATE_OAUTH2_PROXY_CLIENT_SECRET
# Generate with: openssl rand -base64 32
OAUTH2_PROXY_COOKIE_SECRET=GENERATE_NEW_KEY_32BYTES_BASE64
# Marks the session cookie as Secure. Required behind HTTPS (browsers ignore
# Secure cookies over plain HTTP). Set to true when PAPAIA_HOST uses an
# https:// scheme, false otherwise.
OAUTH2_PROXY_COOKIE_SECURE=false

# ###########################################################################
# AI Services
# ###########################################################################

# ═══════════════════════════════════════════════════════════════════════════
# LibreChat - AI Chatbot
# ═══════════════════════════════════════════════════════════════════════════
LIBRECHAT_IMAGE=ghcr.io/danny-avila/librechat:v0.8.5
LIBRECHAT_MONGODB_IMAGE=mongo:8.0.20
LIBRECHAT_MEILISEARCH_IMAGE=getmeili/meilisearch:v1.35.1
LIBRECHAT_VECTORDB_IMAGE=pgvector/pgvector:0.8.0-pg15-trixie
LIBRECHAT_RAGAPI_IMAGE=ghcr.io/danny-avila/librechat-rag-api-dev-lite:latest
LIBRECHAT_EXT_PORT=8000

# ═══════════════════════════════════════════════════════════════════════════
# LiteLLM - AI LLM Proxy
# ═══════════════════════════════════════════════════════════════════════════
LITELLM_IMAGE=ghcr.io/berriai/litellm:v1.83.14.rc.1
LITELLM_DB_IMAGE=postgres:16
LITELLM_PROMETHEUS_IMAGE=prom/prometheus:v3.11.1
LITELLM_EXT_PORT=8200
LITELLM_EXT_PG_PORT=8210
LITELLM_EXT_PROMETHEUS_PORT=8230

# ═══════════════════════════════════════════════════════════════════════════
# N8N - Workflow Automation
# ═══════════════════════════════════════════════════════════════════════════
N8N_IMAGE=docker.n8n.io/n8nio/n8n:2.17.8
N8N_POSTGRES_IMAGE=postgres:16
N8N_EXT_PORT=8400
# Public URL for the oauth2-proxy redirect — must match PAPAIA_HOST:8400.
N8N_PUBLIC_URL=http://host.docker.internal:8400

# ═══════════════════════════════════════════════════════════════════════════
# LocalAI - Local LLM Hosting
# ═══════════════════════════════════════════════════════════════════════════
# LocalAI Image Selection
# Exactly ONE of the following should be active
# CPU (stable, recommended default)
LOCALAI_IMAGE=localai/localai:sha-6c635e8
# NVIDIA GPU (requires NVIDIA Container Toolkit + compatible drivers)
# LOCALAI_IMAGE=localai:sha-6c635e8-gpu-nvidia-cuda-13
LOCALAI_MODEL_INIT_IMAGE=curlimages/curl:latest
LOCALAI_EXT_PORT=8080

# ═══════════════════════════════════════════════════════════════════════════
# DocRAG - Document Retrieval Augmentation Generator
# ═══════════════════════════════════════════════════════════════════════════
DOCRAG_SYNC_IMAGE=rclone/rclone:1.69
DOCRAG_VECTORDB_IMAGE=qdrant/qdrant:v1.13.6
DOCRAG_INGESTER_IMAGE=docrag-ingester:2.85.0
DOCRAG_API_IMAGE=docrag-api:1.27.0
DOCRAG_API_EXT_PORT=8700    # MCP API  -> http://host:8700/mcp
DOCRAG_QDRANT_EXT_PORT=6333 # Qdrant dashboard -> http://host:6333/dashboard

# ═══════════════════════════════════════════════════════════════════════════
# Jina AI Reranker - LLM-Powered Reranking Service
# ═══════════════════════════════════════════════════════════════════════════
JINAAI_RERANKER_IMAGE=ghcr.io/marko-boehm/jina-ai-litellm-reranker:0.2.0
JINAAI_EXT_PORT=8600

# ═══════════════════════════════════════════════════════════════════════════
# MCP Paperless - Per-user Paperless-ngx proxy for LibreChat
# ═══════════════════════════════════════════════════════════════════════════
MCP_PAPERLESS_EXT_PORT=9520
# Must match the values in services/paperless/.env.
PAPERLESS_ADMIN_USER=paperless-admin
PAPERLESS_ADMIN_PASSWORD=GENERATE_NEW_PASSWORD_ADMIN


# ###########################################################################
# Application Services
# ###########################################################################

# ═══════════════════════════════════════════════════════════════════════════
# Homepage - Personal Dashboard
# ═══════════════════════════════════════════════════════════════════════════
HOMEPAGE_IMAGE=ghcr.io/gethomepage/homepage:v1.12.3
HOMEPAGE_EXT_PORT=8300

# ═══════════════════════════════════════════════════════════════════════════
# FireCrawl - Web Crawler
# ═══════════════════════════════════════════════════════════════════════════
FIRECRAWL_IMAGE=ghcr.io/firecrawl/firecrawl@sha256:d06c296fd746355de9c569f17d3dc330b74b20d5aea5f5dcf98fd4a9218081e0
FIRECRAWL_PLAYWRIGHT_IMAGE=ghcr.io/firecrawl/playwright-service@sha256:e8829fb3e87703d0834f0aa0a0965c7574210d7d23a1c58d0bfaf290a0417e6b
FIRECRAWL_REDIS_IMAGE=redis:8.6.1-alpine
FIRECRAWL_RABBITMQ_IMAGE=rabbitmq:3-management
FIRECRAWL_NUCPOSTGRES_IMAGE=ghcr.io/firecrawl/nuq-postgres@sha256:8565e5f46000085c16d247a4354c41e2439dbcf1640f7dd6e6406c0b18c31732
FIRECRAWL_EXT_PORT=3002

# ═══════════════════════════════════════════════════════════════════════════
# Home Assistant - Home Automation
# ═══════════════════════════════════════════════════════════════════════════
HOMEASSISTANT_IMAGE=ghcr.io/home-assistant/home-assistant:2026.4.4
HOME_ASSISTANT_EXT_PORT=8123 # Variable not used, Home Assistant is running in host network mode

# ═══════════════════════════════════════════════════════════════════════════
# Paperless-ng - Document Management System
# ═══════════════════════════════════════════════════════════════════════════
PAPERLESS_IMAGE=ghcr.io/paperless-ngx/paperless-ngx:2.20.10
PAPERLESS_REDIS_IMAGE=docker.io/library/redis:8
PAPERLESS_DB_IMAGE=docker.io/library/postgres:18
PAPERLESS_GOTENBERG_IMAGE=docker.io/gotenberg/gotenberg:8.27
PAPERLESS_TIKA_IMAGE=docker.io/apache/tika:3.2.3.0
PAPERLESS_EXT_PORT=8010
PAPERLESS_PUBLIC_URL=http://host.docker.internal:8010

# ═══════════════════════════════════════════════════════════════════════════
# SearXNG - Privacy-Respecting Metasearch Engine
# ═══════════════════════════════════════════════════════════════════════════
SEARXNG_IMAGE=searxng/searxng:2026.4.24-a7ac696b4
SEARXNG_EXT_PORT=8500

# ###########################################################################
# Infrastructure Services
# ###########################################################################

# ═══════════════════════════════════════════════════════════════════════════
# Nginx Proxy Manager - Reverse Proxy
# ═══════════════════════════════════════════════════════════════════════════
NPM_IMAGE=jc21/nginx-proxy-manager:2.14.0
NPM_ADMIN_EXT_PORT=8100

# ═══════════════════════════════════════════════════════════════════════════
# Keycloak - IAM
# ═══════════════════════════════════════════════════════════════════════════
KEYCLOAK_IMAGE=quay.io/keycloak/keycloak:26.5.6
KEYCLOAK_POSTGRES_IMAGE=postgres:18.3
KEYCLOAK_EXT_PORT=8110

# ═══════════════════════════════════════════════════════════════════════════
# Technitium - DNS Server
# ═══════════════════════════════════════════════════════════════════════════
TECHNITIUM_IMAGE=technitium/dns-server:14.3.0
TECHNITIUM_EXT_PORT=8120
