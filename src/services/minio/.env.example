# ═══════════════════════════════════════════════════════════════════════════
# papAIa — MinIO · environment variables
# by Fidonis GmbH · https://fidonis.de
#
# Image and external ports live in the root .env (MINIO_IMAGE,
# MINIO_EXT_PORT, MINIO_CONSOLE_EXT_PORT).
# MINIO_SERVER_URL is derived from PAPAIA_HOST at compose time — no
# duplicate needed here.
# ═══════════════════════════════════════════════════════════════════════════

# --- Credentials ---
# Must match MINIO_ACCESS_KEY / MINIO_SECRET_KEY in ai/mcp-office-docs/.env.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=GENERATE_MINIO_ROOT_PASSWORD

# ══════════════════════════════════════════════════
# MinIO Cleanup Service
# ══════════════════════════════════════════════════
# Name of the bucket from which expired objects are deleted (required)
CLEANUP_BUCKET=librechat-office-documents
# Optional object prefix to restrict the cleanup scope (empty = all objects)
CLEANUP_PREFIX=generated/
# Retention period in hours – objects older than this value will be deleted (default: 24)
CLEANUP_RETENTION_HOURS=24
# Interval between cleanup runs in seconds (default: 3600 = 1 hour)
CLEANUP_INTERVAL_SECONDS=3600
# Dry-run mode: "true" → log only, do not delete (default: false)
CLEANUP_DRY_RUN=false
