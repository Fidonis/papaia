# ═══════════════════════════════════════════════════════════════════════════
# papAIa — Paperless-ngx · environment variables
# by Fidonis GmbH · https://fidonis.de
# ═══════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────
PAPERLESS_DB=paperless
PAPERLESS_DBUSER=paperless
PAPERLESS_DBPASS=GENERATE_NEW_PASSWORD

# ── Security ──────────────────────────────────────────────────────────────
# Django secret key — must be long, random, and never shared.
PAPERLESS_SECRET_KEY=GENERATE_NEW_SECRET_KEY_64

# ── Bootstrap admin (local account, not OIDC) ─────────────────────────────
# Created on first container start. Use as break-glass access only —
# native login is disabled in docker-compose.yml (SSO-only via Keycloak).
PAPERLESS_ADMIN_USER=paperless-admin
PAPERLESS_ADMIN_PASSWORD=GENERATE_NEW_PASSWORD_ADMIN
PAPERLESS_ADMIN_MAIL=admin@localhost

# ── OIDC / Keycloak ───────────────────────────────────────────────────────
# Must hold the same value as KC_PAPERLESS_CLIENT_SECRET in
# infra/keycloak/.env.
KC_PAPERLESS_CLIENT_SECRET=

# ── OCR ───────────────────────────────────────────────────────────────────
# Primary language for Tesseract OCR (ISO 639-2/T code).
PAPERLESS_OCR_LANGUAGE=deu
# Additional languages to install (space-separated). Container ships with
# eng, deu, ita, spa, fra by default.
# PAPERLESS_OCR_LANGUAGES=

# ── HTTP protocol ─────────────────────────────────────────────────────────
# Set to "https" when PAPAIA_HOST uses HTTPS, "http" otherwise.
PAPERLESS_HTTP_PROTOCOL=http

# ── SSO / Login behaviour ──────────────────────────────────────────────────
# Disable native username/password login; Keycloak SSO becomes the only way in.
# Set to "true" for SSO-only deployments. Emergency access remains possible via
# management commands (docker exec ... createsuperuser).
PAPERLESS_DISABLE_REGULAR_LOGIN=false

# Redirect the login page directly to Keycloak instead of showing the login form.
PAPERLESS_REDIRECT_LOGIN_TO_SSO=false

# Auto-create a Paperless account for any successfully authenticated Keycloak user.
# Set to "false" to restrict access to manually pre-created accounts only.
PAPERLESS_SOCIAL_AUTO_SIGNUP=true

# Sync Keycloak realm roles to Paperless groups on every login.
# Set to "false" to manage group memberships manually inside Paperless.
PAPERLESS_SOCIAL_ACCOUNT_GROUPS_SYNC=true

# OIDC claim that carries the user's group memberships (must match Keycloak mapper).
PAPERLESS_SOCIAL_ACCOUNT_GROUPS_CLAIM=groups

# Keycloak role whose members receive Paperless superuser status.
PAPERLESS_SOCIAL_ACCOUNT_ADMIN_GROUP=admin

# ── Document processing ────────────────────────────────────────────────────
# Set to 0 to disable Tika/Gotenberg. Office document (.docx, .xlsx, .eml)
# ingestion will not work without Tika.
PAPERLESS_TIKA_ENABLED=1

# ── Storage directories ────────────────────────────────────────────────────
# Host-side paths for the three Paperless bind mounts.
# Defaults to subdirectories relative to this compose file.
# Set to an absolute path to use a separate volume or NAS mount.
# MEDIA_DIRECTORY=./data/media
# EXPORT_DIRECTORY=./data/export
# CONSUME_DIRECTORY=./data/consume
